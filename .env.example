# Server Config
PORT=3000
NODE_ENV=development

# Db Config (PostgreSQL)
# Note: If running via Docker Compose, DB_HOST should be set to 'db'
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_local_database_password
DB_NAME=electropi_db

# JWT Auth
JWT_SECRET=replace_this_with_a_secure_random_string
JWT_EXPIRES_IN=1d